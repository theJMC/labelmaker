[Unit]
Description=labelmaker - name label PDF generator web app
After=network.target

[Service]
Type=simple
User=root
Group=root
WorkingDirectory=/root/labelmaker/pdfgen
ExecStart=/root/labelmaker/pdfgen/venv/bin/gunicorn -w 1 -b 0.0.0.0:80 app:app
Restart=on-failure
RestartSec=5

# Optional hardening (safe to remove if it causes issues)
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
